# British Legends Mobile Bridge service settings.
#
# Default for a host-installed cloudflared tunnel:
BL_WEB_HOST=127.0.0.1
BL_WEB_PORT=8080

# Keep this off for the DIY mobile bridge. The browser user taps Reconnect MUD.
BL_CONNECT_ON_START=0

# Enable only while diagnosing telnet protocol issues.
BL_TELNET_DEBUG=0
BL_TELNET_DEBUG_FILE=/opt/british-legends-client/telnet_debug.txt

# British Legends public MUD endpoint.
BL_MUD_HOST=british-legends.com
BL_MUD_PORT=27750

PYTHONUNBUFFERED=1
